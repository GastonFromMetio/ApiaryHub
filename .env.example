APP_NAME=ApiaryHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_AUTO_SEED=false
SEED_ADMIN_NAME="ApiaryHub Admin"
SEED_ADMIN_EMAIL=admin@apiaryhub.local
SEED_ADMIN_PASSWORD=password123
APP_BIND=127.0.0.1
APP_PORT=8000
APP_RUNTIME=web

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=apiaryhub
DB_USERNAME=apiaryhub
DB_PASSWORD=change_me
MYSQL_DATABASE=apiaryhub
MYSQL_USER=apiaryhub
MYSQL_PASSWORD=change_me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=127.0.0.1
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:8000,localhost:8000
SANCTUM_TOKEN_EXPIRATION=720
TRUSTED_PROXIES=127.0.0.1,::1

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
MAIL_QUEUE=mail
QUEUE_WORKER_QUEUE=mail,default
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_MAX_TIME=3600

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_BIND=127.0.0.1
REDIS_BIND=127.0.0.1
MAILPIT_BIND=127.0.0.1

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_ENCRYPTION=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_EHLO_DOMAIN=127.0.0.1
MAIL_FROM_ADDRESS="noreply@apiaryhub.local"
MAIL_FROM_NAME="${APP_NAME}"
BREVO_API_KEY=
FRONTEND_URL=http://127.0.0.1:8000
VITE_BIND=127.0.0.1
VITE_DEV_PORT=5173
VITE_DEV_SERVER_URL=http://localhost:5173
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5173
VITE_USE_POLLING=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
